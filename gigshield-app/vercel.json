{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL (e.g., https://your-backend.example.com)",
      "required": false
    },
    "VITE_WS_URL": {
      "description": "WebSocket backend URL (e.g., wss://your-backend.example.com)",
      "required": false
    }
  },
  "routes": [
    {
      "src": "/(?!api).*",
      "dest": "/index.html",
      "status": 200
    }
  ]
}
