# GigShield — Local development environment
# Copy to .env and fill in real values before running

SECRET_KEY=django-insecure-change-this-in-production-use-50-chars

DEBUG=True
SHADOW_MODE=True
DATA_RETENTION_DAYS=365

# PostgreSQL — create DB manually: createdb gigshield_db
DATABASE_URL=postgres://postgres:yash1505@localhost:5432/gigshield_db

# Redis (local)
REDIS_URL=redis://localhost:6379/0

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Razorpay (get from dashboard.razorpay.com — leave blank for dev simulation)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Weather APIs (leave blank — mock data will be used in dev)
OWM_API_KEY=
ACW_API_KEY=
IMD_API_KEY=

# Optional: Slack for payout failure alerts
SLACK_WEBHOOK_URL=
